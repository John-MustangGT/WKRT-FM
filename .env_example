# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit secrets.

# Required: Anthropic API key for DJ banter generation
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the music library path from settings.toml
# WKRT_MUSIC_DIR=/path/to/your/music

# Optional: path to Google service-account JSON for Google TTS (Neon DJ)
# Sets GOOGLE_APPLICATION_CREDENTIALS automatically if provided.
# WKRT_GOOGLE_CREDENTIALS=/path/to/service-account.json
